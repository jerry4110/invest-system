#!/bin/sh
# Codex 교차 리뷰 훅 (D-014, constitution §2.8)
# 커밋 직후 Codex가 해당 커밋 diff를 리뷰하여 reviews/<short-hash>.md 와 git notes에 기록.
# - codex 미설치/미인증 시 조용히 건너뜀 (커밋을 막지 않는다)
# - 건너뛰기: CODEX_REVIEW=0 git commit ...

[ "$CODEX_REVIEW" = "0" ] && exit 0
command -v codex >/dev/null 2>&1 || { echo "[codex-review] codex CLI 없음 — 건너뜀"; exit 0; }

HASH=$(git rev-parse --short HEAD)
SUBJECT=$(git log -1 --pretty=%s)
OUT="reviews/${HASH}.md"
mkdir -p reviews

echo "[codex-review] ${HASH} 리뷰 중..."
git show HEAD --stat --patch | codex exec --sandbox read-only \
  "너는 시니어 코드 리뷰어다. stdin의 git 커밋 diff를 리뷰하라.
프로젝트 규칙: TDD 필수, 비즈니스 로직은 services/domain에만, 민감정보 평문 금지,
모든 조회 데이터에 as_of, 어댑터 패턴 준수 (자세한 규칙: ../config/constitution.md).
출력 형식(한국어 Markdown):
## 요약 (1-2문장)
## 이슈
- [Critical|Major|Minor] 파일:라인 — 문제와 수정 제안
## 잘한 점 (1-2개)
Critical/Major가 없으면 '## 이슈' 아래 '없음'이라고 써라." > "$OUT" 2>/dev/null

if [ -s "$OUT" ]; then
  { echo "# Codex Review — ${HASH} ${SUBJECT}"; echo; cat "$OUT"; } > "${OUT}.tmp" && mv "${OUT}.tmp" "$OUT"
  git notes add -f -F "$OUT" HEAD 2>/dev/null
  echo "[codex-review] 완료 → ${OUT}"
  grep -q "\[Critical\]" "$OUT" && echo "[codex-review] ⚠️ CRITICAL 이슈 발견 — 다음 태스크 전 해결 필요 (constitution §2.8)"
else
  rm -f "$OUT"
  echo "[codex-review] 리뷰 생성 실패(인증 필요?) — 건너뜀"
fi
exit 0
